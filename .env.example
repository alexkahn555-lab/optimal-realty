# ============================================================================
# OPTIMAL REALTY — ENVIRONMENT. Build reference v2.0, Appendix B.
# Copy to .env.local and fill. .env.local is gitignored.
# ============================================================================

# Canonical origin (D-06 — domain unselected). Falls back to the TK_DOMAIN
# placeholder in config/origin.ts when unset.
NEXT_PUBLIC_SITE_ORIGIN=

# Supabase — service role NEVER reaches a client bundle (no NEXT_PUBLIC_ prefix).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — from-address blocked on D-06 DKIM until the domain is chosen.
RESEND_API_KEY=
LEAD_FROM_ADDRESS=
BROKER_NOTIFY_EMAIL=

# Twilio — kill-switch defaults off until Phase 6.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_ENABLED=0
BROKER_NOTIFY_PHONE=

# Cloudflare Turnstile — bot verification, loaded lazily.
TURNSTILE_SECRET=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Lead IP hashing. Rotating this resets rate-limit memory (acceptable).
LEAD_IP_SALT=

# CRM. Flipping CRM_PROVIDER to 'attio' is the entire cutover. Default 'null'.
CRM_PROVIDER=null
ATTIO_API_KEY=
CRON_SECRET=

# Content gate. 0 in previews, 1 on production from Phase 6.
CONTENT_STRICT=0
